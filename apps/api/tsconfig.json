{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "rootDir": "../..",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@sceneatlas/shared": ["../../packages/shared/src/index.ts"],
      "@sceneatlas/shared/*": ["../../packages/shared/src/*"],
      "@sceneatlas/db": ["../../packages/db/src/index.ts"],
      "@sceneatlas/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": ["src/**/*.ts", "../../packages/shared/src/**/*.ts", "../../packages/db/src/**/*.ts"]
}
